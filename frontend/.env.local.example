# Auth.js v5 (NextAuth) — frontend environment
# These values are read at build/run time by Next.js.

# Secret used to sign the Auth.js session JWT. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-secure-random-value

# Public URL of the deployed frontend.
NEXTAUTH_URL=https://ta.munafaplus.pk

# Backend FastAPI base URL. In Docker this is the internal service name.
API_URL=http://web:8000

# Public-facing API URL used for client-side fetches (rewrites in next.config.ts).
NEXT_PUBLIC_API_URL=http://web:8000
