# ── Required ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./miraj.db
JWT_SECRET_KEY=change-me-to-a-secure-random-value

# ── Optional (with defaults) ───────────────────────────────────────────
# JWT_EXPIRE_MINUTES=60
# ── Portfolio (MEXC integration) ───────────────────────────────────────
# Required for encrypting exchange API keys at rest (Fernet symmetric key).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# OBSIDIAN_VAULT_PATH=
# MIRAI_CORE_PATH=
# FRED_API_KEY=
# DIGEST_HOUR=20
# DIGEST_MINUTE=0

# ── Email Alerts (SMTP) ──────────────────────────────────────────────────
# Used by backend/services/email_service.py to send price alert emails.
# If any of HOST/USER/PASSWORD are missing, email alerts are a silent no-op.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@munafaplus.pk
# SMTP_PASSWORD=
# SMTP_FROM=alerts@munafaplus.pk
# SMTP_FROM_NAME=Miraj Alerts
# SMTP_USE_TLS=true
