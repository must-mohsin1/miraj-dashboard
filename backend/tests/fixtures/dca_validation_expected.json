{
  "schema_version": 1,
  "contract_document": "docs/dca-validation-domain-contract.md",
  "method": "scan-to-scan",
  "assumptions": {
    "fee_percent": 0.04,
    "fee_rate": 0.0004,
    "slippage_percent": 0.05,
    "slippage_rate": 0.0005,
    "ambiguous_gap_hours": 48,
    "minimum_usable_scans": 2,
    "long_rsi_thresholds": [30, 24, 16],
    "short_rsi_thresholds": [80, 92, 95],
    "allocations_percent": [20, 20, 60],
    "allocations_rate": [0.2, 0.2, 0.6],
    "quantity_sizing": "allocation_notional_divided_by_executed_fill_price",
    "long_entry_fill_price": "mark_price * (1 + slippage_rate)",
    "long_exit_fill_price": "mark_price * (1 - slippage_rate)",
    "short_entry_fill_price": "mark_price * (1 - slippage_rate)",
    "short_exit_fill_price": "mark_price * (1 + slippage_rate)",
    "net_pnl_formula": "gross_pnl - entry_slippage_impact - exit_slippage_impact - total_fees"
  },
